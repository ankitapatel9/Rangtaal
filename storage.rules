rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Tutorials — any signed-in user can read, any signed-in user can write
    // (admin-only enforcement is at the app layer; Storage rules can't
    // cross-query Firestore for role checks)
    match /tutorials/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Session media — any signed-in user can read and write
    match /sessions/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
